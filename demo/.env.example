# 复制本文件为 .env，然后在 .env 中填写敏感变量。
# PowerShell 示例：
#   Copy-Item .\.env.example .\.env

# 火山方舟 / 豆包 API Key。
ARK_API_KEY=

# Seed QA 生成使用的豆包模型。
DOUBAO_MODEL=doubao-seed-2-0-pro-260215

# Step 4 多跳合并使用的豆包 thinking 模型。
DOUBAO_THINKING_MODEL=doubao-seed-2-0-pro-260215

# LLM-as-Judge 使用的豆包模型；默认和 thinking 模型一致。
DOUBAO_JUDGE_MODEL=doubao-seed-2-0-pro-260215

# 知识图谱三元组抽取使用的豆包模型。
KG_EXTRACTION_MODEL=doubao-seed-2-0-pro-260215

# Step 2 索引构建和检索运行时使用的本地模型路径。
BGE_M3_PATH=.\models\bge-m3
BGE_RERANKER_PATH=.\models\bge-reranker-v2-m3

# 火山方舟 OpenAI 兼容接口地址。
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 可选：启用火山方舟批量推理任务 Batch Job API。
# 启用后脚本会生成 JSONL、上传 TOS、创建批量推理任务、轮询并下载结果。
DOUBAO_USE_BATCH_INFERENCE=0
VOLC_ACCESSKEY=
VOLC_SECRETKEY=
TOS_BUCKET=
TOS_ENDPOINT=tos-cn-beijing.volces.com
TOS_REGION=cn-beijing
DOUBAO_BATCH_INPUT_PREFIX=agentic-rag-rl/batch/input/
DOUBAO_BATCH_OUTPUT_PREFIX=agentic-rag-rl/batch/output/
DOUBAO_BATCH_PROJECT_NAME=default
DOUBAO_BATCH_COMPLETION_WINDOW=1d
# 默认会从 doubao-seed-2-0-pro-260215 拆出 foundation model 和 version。
DOUBAO_BATCH_FOUNDATION_MODEL=
DOUBAO_BATCH_MODEL_VERSION=
DOUBAO_BATCH_CUSTOM_MODEL_ID=

# 请求超时时间，单位：秒。
DOUBAO_TIMEOUT_SECONDS=60

# XingJianYa / OpenAI-compatible 在线接口。
# 选择 --llm-provider xingjianya 时使用；不支持火山方舟 Batch Job。
XINGJIANYA_API_KEY=
XINGJIANYA_BASE_URL=https://api.xinjianya.top/v1
XINGJIANYA_MODEL=deepseek-v4-pro
XINGJIANYA_KG_MODEL=
XINGJIANYA_THINKING_MODEL=
XINGJIANYA_JUDGE_MODEL=
XINGJIANYA_TIMEOUT_SECONDS=60
