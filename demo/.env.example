# 复制本文件为 .env，然后在 .env 中填写敏感变量。
# PowerShell 示例：
#   Copy-Item .\.env.example .\.env

# 默认在线模型供应商：NewAPI / OpenAI-compatible。
NEWAPI_API_KEY=
NEWAPI_BASE_URL=https://api.6i2.com/v1
NEWAPI_MODEL=gpt-5.5
NEWAPI_KG_MODEL=
NEWAPI_THINKING_MODEL=
NEWAPI_JUDGE_MODEL=
NEWAPI_TIMEOUT_SECONDS=60

# 可选在线模型供应商：RightCode / OpenAI-compatible。
RIGHTCODE_API_KEY=
RIGHTCODE_BASE_URL=https://api.right.codes/v1
RIGHTCODE_MODEL=gpt-5.5
RIGHTCODE_KG_MODEL=
RIGHTCODE_THINKING_MODEL=
RIGHTCODE_JUDGE_MODEL=
RIGHTCODE_TIMEOUT_SECONDS=60

# Step 2 索引构建和检索运行时使用的本地模型路径。
BGE_M3_PATH=.\models\bge-m3
BGE_RERANKER_PATH=.\models\bge-reranker-v2-m3
